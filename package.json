{
  "name": "logz-panel",
  "displayName": "LogZ Panel",
  "description": "Adds a panel to view logz logs",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.103.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "dist/extension/extension.js",
  "contributes": {
    "taskDefinitions": [
      {
        "type": "logz-wrapper",
        "required": [
          "wrappedTask"
        ],
        "properties": {
          "wrappedTask": {
            "type": "string",
            "description": "Label of the task to wrap"
          }
        }
      }
    ],
    "viewsContainers": {
      "panel": [
        {
          "id": "logzPanel",
          "title": "Logs",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "logzPanel": [
        {
          "id": "logzPanelView",
          "name": "Log Stream",
          "type": "webview"
        }
      ]
    }
  },
  "private": true,
  "workspaces": [
    "extension",
    "webview",
    "shared"
  ],
  "scripts": {
    "watch": "npm-run-all --parallel watch:extension watch:webview",
    "watch:extension": "npm run watch --workspace=extension",
    "watch:webview": "npm run watch --workspace=webview"
  },
  "devDependencies": {
    "eslint": "^9.39.1",
    "npm-run-all": "^4.1.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0"
  }
}
