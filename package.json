{
  "name": "log-panelz",
  "displayName": "Log PanelZ",
  "description": "Adds a panel to view logz",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.103.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "dist/extension/extension.js",
  "contributes": {
    "taskDefinitions": [
      {
        "type": "log-panel-wrapper",
        "required": [
          "unixCommand"
        ],
        "properties": {
          "unixCommand": {
            "type": "string",
            "description": "the unix shell command"
          }
        }
      }
    ],
    "viewsContainers": {
      "panel": [
        {
          "id": "logPanel",
          "title": "Logs",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "logPanel": [
        {
          "id": "logPanelView",
          "name": "Logs2",
          "type": "webview"
        }
      ]
    }
  },
  "private": true,
  "workspaces": [
    "extension",
    "webview",
    "shared"
  ],
  "scripts": {
    "watch": "npm-run-all --parallel watch:extension watch:webview",
    "watch:extension": "npm run watch --workspace=extension",
    "watch:webview": "npm run watch --workspace=webview"
  },
  "devDependencies": {
    "eslint": "^9.39.1",
    "npm-run-all": "^4.1.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0"
  }
}
